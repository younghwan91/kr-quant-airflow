# --- Kiwoom API ---
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=

# --- DART OpenAPI (분기 실적: 순이익·매출·영업이익 → PEAD / Minervini Code 33) ---
# 무료 발급: https://opendart.fss.or.kr (개인, 일 20,000콜 — 키 단위 한도, IP 무관)
# 보조키(_2, _3...)를 넣으면 일한도(020) 시 자동 로테이션 → 키 개수만큼 실효 콜한도 증가.
DART_API_KEY=
DART_API_KEY_2=
DART_API_KEY_3=

# --- Airflow ---
AIRFLOW_UID=50000
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
AIRFLOW__WEBSERVER__SECRET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me

# --- Airflow metadata DB (internal, separate from app data) ---
AIRFLOW_META_DB=airflow_meta
AIRFLOW_META_USER=airflow
AIRFLOW_META_PASSWORD=change_me

# --- TimescaleDB (shared app data, exposed on LAN) ---
TIMESCALE_DB=kr_quant
TIMESCALE_USER=kr_quant
TIMESCALE_PASSWORD=change_me
TIMESCALE_PORT=5432

# --- kr-quant sqlite path (inside container, mounted from ../kr-quant) ---
KR_QUANT_SQLITE_PATH=/opt/kr-quant/data/kr_quant.db
